NODE_ENV=production
PORT=3001

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/amazon-now?retryWrites=true&w=majority

# Groq AI
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant

# AWS (S3 + CloudFront for product images)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ap-south-1
S3_MEDIA_BUCKET=your-bucket-name
CLOUDFRONT_URL=https://xxxx.cloudfront.net

# Your EC2 / frontend URL
FRONTEND_URL=http://YOUR_EC2_IP:3000
